#!/bin/bash
# ==========================================================
# Solopreneur OS: Pre-Commit Bouncer
# ==========================================================
# This script runs automatically when you type `git commit`.
# If it fails, the commit is aborted.

echo "🛡️  Running OS Pre-Commit Checks..."

# 1. SECRET SCANNER (Prevents AI from hardcoding API keys)
echo "🔎 Scanning for leaked secrets..."
FORBIDDEN_PATTERNS="(sk-[a-zA-Z0-9]{20,}|sk_live_[a-zA-Z0-9]+|AKIA[0-9A-Z]{16})"

# Check only the files being staged for commit
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -n "$STAGED_FILES" ]; then
    for FILE in $STAGED_FILES; do
        if grep -qE "$FORBIDDEN_PATTERNS" "$FILE"; then
            echo "❌ ERROR: Potential API key or secret found in: $FILE"
            echo "💡 FIX: Please move the secret to your .env file and use environment variables."
            exit 1
        fi
    done
fi

# 2. RUN LINTER / TYPE CHECKER
echo "🧹 Running Linters..."
# Fail fast with descriptive errors if ANY linter exits with a non-zero code
uv run ruff check . --fix || { echo "❌ ERROR: Ruff linting failed. Fix formatting/type errors before committing."; exit 1; }
uv run ruff format . || { echo "❌ ERROR: Ruff formatting failed."; exit 1; }
npx @biomejs/biome check --write . || { echo "❌ ERROR: Biome linting/formatting failed."; exit 1; }

# Re-stage ONLY the files that were originally staged, in case the linters auto-fixed them!
if [ -n "$STAGED_FILES" ]; then
    git add $STAGED_FILES
fi

# 3. RUN TESTS
echo "🧪 Running Test Suite..."
uv run pytest || { echo "❌ ERROR: Python tests failed. The Engineering Agent introduced a regression."; exit 1; }
npx vitest run --passWithNoTests || { echo "❌ ERROR: JS/TS tests failed. The Engineering Agent introduced a regression."; exit 1; }

echo "✅ All checks passed. Committing safely."
exit 0