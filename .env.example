# ==========================================
# Solopreneur OS Configuration
# Copy this file to .env and add your keys
# ==========================================

# Routing Configuration
# If true, the OS routes to the best model per skill (requires both keys below)
SMART_ROUTING=true

# The default provider if SMART_ROUTING=false (Options: openai, anthropic)
DEFAULT_PROVIDER=openai

# API Keys
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here