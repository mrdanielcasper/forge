{
  "name": "project-harness",
  "version": "1.0.0",
  "description": "This repository is a lightweight, fully autonomous operating system for building and scaling a one-person software company.",
  "main": "index.js",
  "type": "module",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "biome check .",
